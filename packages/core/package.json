{
  "name": "@tessera/core",
  "version": "0.1.0",
  "description": "Tessera pure domain: CIP-179 data-model types, the DataSource seam, portable config, and the JSON-safe wire codec. No I/O, no runtime coupling.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "type-check": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "cip-179": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
