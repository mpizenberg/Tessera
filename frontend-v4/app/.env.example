# Copy to `.env` and fill in.

# Authenticated Koios token. The free (anonymous) tier does not send CORS
# headers, so a token is required for browser requests. Get one at
# https://koios.rest (tier 1 is free).
VITE_KOIOS_TOKEN=

# Network: "preview" (default) or "mainnet"
# VITE_NETWORK=preview

# HTTP gateway for dereferencing ipfs:// content anchors (external-content
# presentation docs, voter rationales). Must end with a trailing slash.
# Defaults to https://ipfs.io/ipfs/
# VITE_IPFS_GATEWAY=https://ipfs.io/ipfs/
