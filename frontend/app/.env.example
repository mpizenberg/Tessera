# Copy to `.env` and fill in.

# Authenticated Koios token. The free (anonymous) tier does not send CORS
# headers, so a token is required for browser requests. Get one at
# https://koios.rest (tier 1 is free).
VITE_KOIOS_TOKEN=

# Network: "preview" (default) or "mainnet"
# VITE_NETWORK=preview

# Note: the Koios token above can also be overridden at runtime in Settings.
# IPFS reads race a built-in list of public gateways (no config). IPFS *pinning*
# (authoring external content / rationales) uses per-provider API tokens entered
# in Settings (Pinata / Blockfrost / NMKR), stored only in the browser.
