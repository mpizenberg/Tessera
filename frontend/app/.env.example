# Copy to `.env` and fill in.

# Network: "preview" (default) or "mainnet"
# VITE_NETWORK=preview

# Tier-1 serving backend URL. When set, the app both reads its snapshot from
# this backend and builds transactions from its protocol parameters — so no
# Koios token is needed at all (transactions are still signed by your wallet).
# Leave it unset to use Koios directly instead (the power-user/offline path),
# which then needs a Koios token pasted in the app's Settings. For local
# development against `@tessera/backend` (`pnpm --filter @tessera/backend dev`):
# VITE_INDEXER_URL=http://localhost:8787

# IPFS reads race a built-in list of public gateways (no config). IPFS *pinning*
# (authoring external content / rationales) uses per-provider API tokens entered
# in Settings (Pinata / Blockfrost / NMKR), stored only in the browser.
