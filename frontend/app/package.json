{
  "name": "tessera-app",
  "version": "0.1.0",
  "description": "Tessera — CIP-179 on-chain surveys & polls frontend (SolidJS)",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@evolution-sdk/evolution": "^0.5.9",
    "@mattpiz/tlock-js": "0.10.0",
    "@noble/hashes": "^2.2.0",
    "@solidjs/router": "^0.16.1",
    "@tessera/core": "workspace:*",
    "@tessera/koios": "workspace:*",
    "cip-179": "workspace:*",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.4.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.0"
  }
}
