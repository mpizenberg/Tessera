# Tessera backend — all values are optional; sane defaults let it run with none.
# Copy to `.env` to override.

# Network to index: mainnet | preview. Default: preview.
NETWORK=preview

# Koios REST base URL. Default: derived from NETWORK.
# KOIOS_URL=https://preview.koios.rest/api/v1

# Optional Koios bearer token. Server-side fetch is NOT CORS-bound, so the
# anonymous tier works with no token; set one only for rate headroom.
# KOIOS_TOKEN=

# Only index CIP-179 txs at/after this ISO date. Default: 2026-06-01T00:00:00Z.
# SINCE=2026-06-01T00:00:00Z

# HTTP port. Default: 8787.
PORT=8787

# Snapshot refresh interval, seconds. Default: 180.
REFRESH_SECONDS=180

# SQLite cache file. Default: ./tessera-cache.sqlite. Use :memory: for no file.
# DB_PATH=./tessera-cache.sqlite
